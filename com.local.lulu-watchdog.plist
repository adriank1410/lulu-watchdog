<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.local.lulu-watchdog</string>

  <!-- __HOME__ is replaced with the user's home directory by install.sh.
       The script is executed directly (not via "zsh script") so that
       System Settings > Login Items shows "lulu-watchdog", not "zsh". -->
  <key>ProgramArguments</key>
  <array>
    <string>__HOME__/Library/Application Support/LuLuWatchdog/lulu-watchdog</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>ProcessType</key>
  <string>Background</string>

  <key>StartInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>/dev/null</string>

  <key>StandardErrorPath</key>
  <string>/dev/null</string>
</dict>
</plist>
